# Kaggle API credentials
# Download from https://www.kaggle.com/account and place kaggle.json in ~/.kaggle/
# or set KAGGLE_USERNAME and KAGGLE_KEY here
KAGGLE_USERNAME=
KAGGLE_KEY=

# World Bank API (public, no auth required)
WORLD_BANK_API_BASE=https://api.worldbank.org/v2/country

# FIFA data fetch (public, no auth required)
FIFA_FETCH_DELAY=1

# Logging
LOG_LEVEL=INFO
